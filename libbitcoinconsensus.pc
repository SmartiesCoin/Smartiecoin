prefix=/usr/local
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: Smartiecoin Core consensus library
Description: Library for the Bitcoin consensus protocol.
Version: 1.0.2.2
Libs: -L${libdir} -lbitcoinconsensus
Cflags: -I${includedir}
Requires.private: libcrypto
